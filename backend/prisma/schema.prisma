generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = "postgresql://pipeforge:pipeforge123@127.0.0.1:5433/prisma_shadow"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())

  pipelines Pipeline[]
}

model Pipeline {
  id          String   @id @default(uuid())
  name        String
  description String?
  provider    String   @default("AWS")
  status      String   @default("idle")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id])

  stages     Stage[]
  executions Execution[]
}

model Stage {
  id         String @id @default(uuid())
  name       String
  type       String
  orderIndex Int
  config     Json   @default("{}")
  decorators Json?  @default("[]")

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
}

model Execution {
  id         String    @id @default(uuid())
  status     String    @default("pending")
  duration   Int?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  logs       Json      @default("[]")
  provider   String    @default("AWS")
  forceFail  Boolean   @default(false)
  failStage  String?

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
}

model Plugin {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   @default("notification")
  enabled     Boolean  @default(false)
  config      Json?    @default("{}")
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Experiment {
  id          String    @id @default(uuid())
  name        String
  description String?
  status      String    @default("running")
  modelType   String    @default("xgboost")
  metrics     Json      @default("{}")
  params      Json      @default("{}")
  tags        Json      @default("[]")
  duration    Int?
  pipelineId  String?
  createdAt   DateTime  @default(now())
  finishedAt  DateTime?
}

model ModelVersion {
  id           String    @id @default(uuid())
  name         String
  version      Int
  stage        String    @default("staging")
  framework    String    @default("xgboost")
  metrics      Json      @default("{}")
  artifactPath String?
  description  String?
  experimentId String?
  createdAt    DateTime  @default(now())
  promotedAt   DateTime?
}

model DataValidationRun {
  id           String   @id @default(uuid())
  datasetName  String
  status       String   @default("passed")
  rowCount     Int      @default(0)
  checksPassed Int      @default(0)
  checksFailed Int      @default(0)
  results      Json     @default("[]")
  pipelineId   String?
  createdAt    DateTime @default(now())
}

model DriftAlert {
  id          String    @id @default(uuid())
  alertType   String    @default("data")
  severity    String    @default("medium")
  feature     String?
  psiScore    Float     @default(0)
  threshold   Float     @default(0.2)
  status      String    @default("open")
  modelName   String?
  description String?
  autoRetrain Boolean   @default(false)
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
}

model Feature {
  id          String   @id @default(uuid())
  name        String   @unique
  entity      String
  valueType   String   @default("float")
  description String?
  source      String?
  tags        Json     @default("[]")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
